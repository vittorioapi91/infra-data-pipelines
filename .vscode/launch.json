{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "EDGAR - Download Quarter Filings",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/fundamentals/edgar/edgar.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--download-raw-quarter-filings",
                "--year",
                "${input:edgarYear}",
                "--quarter",
                "${input:edgarQuarter}",
                "--form-type",
                "${input:edgarFormType}"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "EDGAR - Scrape Quarter Filings",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/fundamentals/edgar/edgar.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--filings-zip",
                "--scrape-filings",
                "--year",
                "${input:edgarYear}",
                "--quarter",
                "${input:edgarQuarter}",
                "--form-type",
                "${input:edgarFormType}",
                "--debug"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "EDGAR - Generate Catalog (All Companies)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/fundamentals/edgar/edgar.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--generate-catalog"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "FRED - Generate Catalog",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/macro/fred/fred.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--generate-catalog",
                "--full-category-search"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
